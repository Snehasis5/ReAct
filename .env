OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openrouter/free

# Optional overrides
MAX_REPLAN_ATTEMPTS=3
TOOL_TIMEOUT_SECONDS=15

# Set to "mock" to run the whole system with a deterministic offline stub LLM
# (no network calls). Useful for grading/CI without burning API credits.
# Set to "live" to call the real OpenRouter API.
LLM_MODE=live
